# backend/.env.example
 
# ── Server ──────────────────────────────────
PORT=4000
NODE_ENV=production
 
# ── MongoDB ─────────────────────────────────
MONGO_URI=mongodb+srv://<user>:<pass>@cluster0.xxxxx.mongodb.net/pharmanews
 
# ── Redis (BullMQ) ───────────────────────────
REDIS_URL=rediss://:password@your-upstash-endpoint:6380
 
# ── News APIs ────────────────────────────────
NEWSAPI_KEY=your_newsapi_key_here
GNEWS_KEY=your_gnews_key_here
 
# ── AI Summary (optional) ────────────────────
OPENAI_API_KEY=sk-...
 
# ── Email (n8n uses this via SMTP node) ──────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password
 
# ── Security ─────────────────────────────────
CORS_ORIGIN=https://your-frontend.vercel.app
UNSUBSCRIBE_SECRET=a_long_random_string_here